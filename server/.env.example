# Neo4j（本地 Docker 示例：bolt://localhost:7687）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Postgres（本地 Docker）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smartpet_duel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_SSL=false

# LLM（OpenAI-compatible）
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_CHAT=
LLM_MODEL_EMBED=
LLM_TIMEOUT_MS=10000
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL_CHAT=
LLM_FALLBACK_MODEL_EMBED=
COMMENTARY_ENABLED=false
COMMENTARY_MAX_TOKENS=96

# 对战：人类单方超时秒数（PvE），到期由规则 AI 代打；测试可设为 0
BATTLE_HUMAN_TURN_TIMEOUT_SEC=120
BATTLE_AUTOPILOT_DIFFICULTY=medium

# Channel signature secrets（渠道验签）
CHANNEL_SIGN_SECRET_OPENCLAW=
CHANNEL_SIGN_SECRET_DOUBAO=

# Skill 接入层：设为 false 时不挂载 /skill/v1（与根 API 语义相同，供自动化 / OpenClaw 等调用）
# SKILL_LAYER_ENABLED=true
