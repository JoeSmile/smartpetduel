# Neo4j（本地 Docker 示例：bolt://localhost:7687）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# Postgres（本地 Docker）
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=smartpet_duel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password
POSTGRES_SSL=false

# LLM（OpenAI-compatible）
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL_CHAT=
LLM_MODEL_EMBED=
LLM_TIMEOUT_MS=10000
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL_CHAT=
LLM_FALLBACK_MODEL_EMBED=
COMMENTARY_ENABLED=false
COMMENTARY_MAX_TOKENS=96

# Channel signature secrets（渠道验签）
CHANNEL_SIGN_SECRET_OPENCLAW=
CHANNEL_SIGN_SECRET_DOUBAO=
